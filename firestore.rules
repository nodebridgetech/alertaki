rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read own profile, write own profile
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;

      // Contacts: own read, write via Cloud Function only
      match /contacts/{contactId} {
        allow read: if request.auth.uid == uid;
        allow delete: if request.auth.uid == uid;
        allow create, update: if false;
      }

      // ContactOf: own read only
      match /contactOf/{ownerId} {
        allow read: if request.auth.uid == uid;
        allow write: if false;
      }

      // Blocked: own read and write
      match /blockedUsers/{blockedId} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    // Alerts: create by author, read by authenticated users
    match /alerts/{alertId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null;
    }

    // Recipients: collection group query requires recursive wildcard
    match /{path=**}/recipients/{recipientId} {
      allow read: if request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // Invites: create by sender, read/update by involved parties
    match /invites/{inviteId} {
      allow create: if request.auth.uid == request.resource.data.fromUid;
      allow read: if request.auth.uid == resource.data.fromUid
                  || request.auth.uid == resource.data.toUid;
      allow update: if request.auth.uid == resource.data.toUid;
    }
  }
}
